# Security OKF (okpack-sec) domain pack — secrets & delivery. COPY to .env; never commit .env.
# --- delivery ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
# --- models (at least one provider) ---
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# --- web search (optional, for web-augmented digests) ---
TAVILY_API_KEY=
EXA_API_KEY=
# --- MCP query surface (optional) ---
OKENGINE_MCP_TOKEN=

# --- agent chat (optional: the reader's Chat tab → THE agent) ---
# Exposes Hermes as an OpenAI-compatible HTTP API the reader relays to. The Chat tab
# only appears when this is enabled AND OKENGINE_AGENT_API is set on the reader (compose
# defaults OKENGINE_AGENT_KEY=${API_SERVER_KEY}). After enabling, lock down the chat
# platform's tools and register the search collection — see docs/deploy-a-new-domain.md
# ("Agent chat") — or an untrusted visitor drives an agent with shell/code access.
API_SERVER_ENABLED=          # true to turn it on
API_SERVER_KEY=              # bearer token (generate: openssl rand -hex 24); reused as OKENGINE_AGENT_KEY
API_SERVER_PORT=8642
API_SERVER_HOST=0.0.0.0      # 0.0.0.0 so the bridge-networked reader can reach it
API_SERVER_MODEL_NAME=OKEngine Agent
# Set this on the reader to point it at the api_server (host-network gateway):
OKENGINE_AGENT_API=          # e.g. http://host.docker.internal:8642/v1

# --- predictions (engine-template forecasting lane) ---
# Narrow prediction-candidate-watch to your forward-lookable entity types (else it
# considers every entity, incl. the ATT&CK/CVE reference catalog). Comma-separated.
PREDICTION_CANDIDATE_TYPES=threat-actor,intrusion-set,malware,campaign
