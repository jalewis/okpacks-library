# okpack-example — example knowledge vault — secrets & delivery. COPY to .env; never commit .env.
# --- delivery ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
# --- models (at least one provider) ---
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# --- web search (optional, for web-augmented digests) ---
TAVILY_API_KEY=
EXA_API_KEY=
# --- network exposure (LOCAL-FIRST) ---
# Host ports bind to localhost by default — the stack is reachable only from this
# machine. To expose reader/MCP on the LAN, set this to 0.0.0.0 (a deliberate
# choice) AND set real secrets below.
OKENGINE_BIND=127.0.0.1
# --- MCP query surface ---
# Leave blank for a loopback-only deploy (OKENGINE_BIND=127.0.0.1). Generate and set a
# real secret here (e.g. `openssl rand -hex 32`) BEFORE flipping OKENGINE_BIND to 0.0.0.0
# — never expose the MCP with a shared/default token.
OKENGINE_MCP_TOKEN=
# --- reader auth (required once OKENGINE_BIND=0.0.0.0; optional on loopback) ---
OKENGINE_READER_PASSWORD=
