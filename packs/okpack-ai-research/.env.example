# AI / LLM Research Watch domain pack. COPY to .env; never commit .env.

# --- engine / runtime ---
# Absolute path to the OKEngine checkout pinned by engine.version.
ENGINE_DIR=
# Container UID/GID with write access to this pack. deploy.sh DEFAULTS these to your own
# uid ($(id -u)), so a self-owned clone just works — leave them unset. Pin a fixed uid
# (and chown the tree to it) only for a portable/shared vault:
# HERMES_UID=10000
# HERMES_GID=10000

# --- delivery ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# --- models (at least one provider) ---
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# --- network exposure (LOCAL-FIRST) ---
# Host ports bind to localhost by default — reader/MCP are reachable only from this
# machine. To expose on the LAN, set this to 0.0.0.0 (a deliberate choice) AND set
# real secrets below.
OKENGINE_BIND=127.0.0.1

# --- query surfaces ---
# okengine-mcp (port 8830): leave blank for a loopback-only deploy (OKENGINE_BIND=127.0.0.1).
# Generate and set a real secret here (e.g. `openssl rand -hex 32`) BEFORE flipping
# OKENGINE_BIND to 0.0.0.0 — never expose the MCP with a shared/default token.
OKENGINE_MCP_TOKEN=
# okengine-reader (port 9300): if set, requires HTTP Basic auth (required once
# OKENGINE_BIND=0.0.0.0; optional on loopback).
OKENGINE_READER_PASSWORD=
