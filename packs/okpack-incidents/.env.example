# okpack-incidents — Security Incidents & Identities — secrets & delivery. COPY to .env; never commit .env.
# --- delivery ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
# --- timezone (optional; default UTC) ---
# Sets the container clock (logs/timestamps) AND the timezone cron-plus interprets schedule
# exprs in — so `30 13 * * *` fires at 13:30 LOCAL (DST-aware), not 13:30 UTC. Leave unset for
# UTC; set your locale for local-time schedules. next_run_at is always stored in UTC.
# TZ=America/New_York
# --- daily-brief hour (optional) ---
# The one knob for WHEN your reader-facing daily briefs run: every brief lane ships a
# `@morning[:MM]` schedule that expands to this HOUR (gateway-local TZ) at deploy, so all
# your briefs cluster in your morning instead of each lane hardcoding a time. Default 7 (07:00).
# Set your morning; redeploy crons to apply. (Set TZ above too, or the hour is UTC.)
# OKENGINE_BRIEF_HOUR=7
# --- off-peak deferral (optional) ---
# Bulk backfill drains (raw/entity/concept-backfill) skip firing during these UTC peak hours,
# so they don't run at premium pricing (e.g. DeepSeek's 2x window, mid-2026: 01-04 + 06-10 UTC).
# Comma list of UTC hour ranges, half-open (a-b = [a,b)). Unset = no deferral; the drain defers to
# the next off-peak fire (queue accumulates, no data loss). The check is in UTC regardless of TZ.
# CRON_DEFER_UTC_HOURS=1-4,6-10
# --- models (at least one provider) ---
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# --- web search (optional, for web-augmented digests) ---
TAVILY_API_KEY=
EXA_API_KEY=
# --- network exposure (LOCAL-FIRST) ---
# Host ports bind to localhost by default — the stack is reachable only from this
# machine. To expose reader/MCP on the LAN, set this to 0.0.0.0 (a deliberate
# choice) AND set real secrets below.
OKENGINE_BIND=127.0.0.1
# --- MCP query surface ---
# Ships with a generic default token (okengine-local) so a fresh deploy works
# out of the box. Safe ONLY while OKENGINE_BIND=127.0.0.1. Set a real secret here
# before flipping OKENGINE_BIND to 0.0.0.0.
OKENGINE_MCP_TOKEN=okengine-local
# --- reader auth (required once OKENGINE_BIND=0.0.0.0; optional on loopback) ---
OKENGINE_READER_PASSWORD=
